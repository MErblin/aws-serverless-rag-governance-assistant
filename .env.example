# Application Settings
APP_NAME=GRC RAG Governance Assistant
APP_VERSION=0.1.0
DEBUG=false

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit Settings
STREAMLIT_PORT=8501

# ── LLM Provider ────────────────────────────────────────────────────────────
# Options: "gemini" (default, free) | "ollama" (local, no API key needed)
LLM_PROVIDER=gemini

# Google Gemini (free tier — 1,500 req/day)
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Ollama (only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Embeddings ───────────────────────────────────────────────────────────────
# Local HuggingFace model — no API key needed, runs on CPU
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Storage ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=documents
PROJECTS_ROOT_DIR=./data/projects

# ── AWS / S3 ─────────────────────────────────────────────────────────────────
# Leave S3_BUCKET empty to skip S3 — documents will be stored locally only
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name-here
S3_PREFIX=grc-docs/

# ── Document Processing ───────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_FILE_SIZE_MB=10
