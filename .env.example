# Application Settings
APP_NAME=DocuChat RAG
APP_VERSION=0.1.0
DEBUG=true

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit Settings
STREAMLIT_PORT=8501

# Ollama Settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embedding Model (HuggingFace)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ChromaDB Settings
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=documents

# Document Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_FILE_SIZE_MB=10
